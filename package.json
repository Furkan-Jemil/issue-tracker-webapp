{
  "name": "issue-tracker-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "mobile": "npm run --prefix apps/mobile start"
  },
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "turbo": "^2.0.4"
  }
}
