{
  "name": "issue-tracker-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "mobile": "npm run --prefix apps/mobile start",
    "api:dev": "npm run dev --prefix apps/api",
    "server:start": "npm run start:prod --prefix apps/api"
  },
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "turbo": "^2.0.4"
  }
}
