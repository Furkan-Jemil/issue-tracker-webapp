{
  "name": "@workspace/api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend API — migration target for the Hono server. Single source of truth for /api/*.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "prisma generate --schema=../../packages/database/prisma/schema.prisma && tsc --noEmit -p tsconfig.build.json",
    "start:prod": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate --schema=../../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@better-auth/infra": "^0.1.14",
    "better-auth": "^1.6.12",
    "bcryptjs": "^3.0.3",
    "@vercel/blob": "^2.3.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3",
    "@workspace/database": "*",
    "@workspace/shared": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "25.5.0",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "prisma": "7.6.0"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
