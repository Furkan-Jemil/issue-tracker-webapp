generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================
enum Role {
  USER
  TESTER
  ADMIN
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Severity {
  MINOR
  MAJOR
  CRITICAL
}

enum IssueType {
  BUG
  IMPROVEMENT
}

enum HistoryEvent {
  CREATED
  STATUS_CHANGED
  UPDATED
  COMMENTED
}

// =============================================================================
// AUTH MODELS (Better Auth compatible)
// =============================================================================
model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  password      String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions       Session[]
  accounts       Account[]
  issues         Issue[]        @relation("IssueCreator")
  comments       Comment[]
  notifications  Notification[]
  historyActions IssueHistory[] @relation("HistoryActor")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// =============================================================================
// DOMAIN MODELS
// =============================================================================
model Issue {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(255)
  description String      @db.Text
  type        IssueType
  priority    Priority
  severity    Severity
  url         String?
  status      IssueStatus @default(OPEN)
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  creator       User           @relation("IssueCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  screenshots   Screenshot[]
  comments      Comment[]
  history       IssueHistory[]
  notifications Notification[]

  @@index([createdBy])
  @@index([status])
  @@index([priority])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@index([status, priority])
  @@index([createdBy, status])
  @@map("issues")
}

model Screenshot {
  id        String   @id @default(uuid())
  issueId   String
  url       String
  filename  String
  mimeType  String
  sizeBytes Int
  order     Int      @default(0)
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([issueId, order])
  @@map("screenshots")
}

model Comment {
  id        String   @id @default(uuid())
  issueId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([issueId])
  @@index([issueId, createdAt])
  @@map("comments")
}

model IssueHistory {
  id          String       @id @default(uuid())
  issueId     String
  actorId     String
  eventType   HistoryEvent
  description String       @db.Text
  metadata    Json?
  createdAt   DateTime     @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User  @relation("HistoryActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([issueId])
  @@index([issueId, createdAt])
  @@index([actorId])
  @@index([eventType])
  @@map("issue_history")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  issueId   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([issueId])
  @@map("notifications")
}
