{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_TRUSTED_ORIGINS",
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "NODE_ENV",
        "BLOB_READ_WRITE_TOKEN",
        "ALLOWED_ORIGINS",
        "NEXT_PUBLIC_APP_URL",
        "API_PROXY_TARGET",
        "PORT",
        "HOST"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}
